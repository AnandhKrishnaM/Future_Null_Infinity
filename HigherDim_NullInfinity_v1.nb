Notebook[{

Cell[CellGroupData[{

Cell["Higher Dimensional Asymptotically Flat Spacetime \[LongDash] Future Null \
Infinity Analysis (v1)", "Title"],

Cell["Anandh Krishna M \[LongDash] Masters Thesis Work", "Subtitle"],

Cell["\<\
This notebook implements the analysis of higher dimensional (D \[GreaterEqual] \
4) asymptotically flat spacetimes using the xAct framework for Mathematica. \
The code follows the Bondi-Sachs formalism adapted to D spacetime dimensions, \
studying the structure of future null infinity (\[ScriptCapitalI]\[PlusMinus]) \
and the associated asymptotic symmetry algebra (generalised BMS group).\
\>", "Text"],

Cell[CellGroupData[{

Cell["1. Prerequisites and Package Loading", "Section"],

Cell["\<\
Requires the xAct suite:  xTensor, xCoba, xPert, and (optionally) Invar.
Install via https://www.xact.es/  or  the Mathematica Package Manager.\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
    RowBox[{"Load", " ", "xAct", " ", "packages"}], ";",
    RowBox[{
     RowBox[{
      RowBox[{"adjust", " ", "the", " ", "path", " ", "if", " ", "xAct", " ",
       "is", " ", "not", " ", "on", " ", "the", " ", "default", " ", "Mathematica"}], " ",
      RowBox[{"package", " ", "search", " ", "path"}]}]}]}], " ", "*)"}],
  "\[IndentingNewLine]",
  RowBox[{
   RowBox[{"Needs", "[", "\"\<xAct`xTensor`\>\"", "]"}], ";", "\n",
   RowBox[{"Needs", "[", "\"\<xAct`xCoba`\>\"", "]"}], ";", "\n",
   RowBox[{"Needs", "[", "\"\<xAct`xPert`\>\"", "]"}], ";"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
    "Set", " ", "the", " ", "number", " ", "of", " ", "spacetime", " ",
    "dimensions"}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{
   RowBox[{"D", " ", "=", " ", "5"}], ";",
   RowBox[{"(*", " ",
    RowBox[{
     "Change", " ", "to", " ", "any", " ", "integer", " ",
     RowBox[{"\[GreaterEqual]", " ", "4"}]}], " ", "*)"}]}]}]], "Input"],

}, Open  ]],

Cell[CellGroupData[{

Cell["2. Manifold, Bundle and Index Definitions", "Section"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
    "Define", " ", "the", " ", "D", "\[Hyphen]dimensional", " ",
    "spacetime", " ", "manifold"}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{
   RowBox[{"DefManifold", "[",
    RowBox[{"M", ",", "D", ",",
     RowBox[{"{",
      RowBox[{
       RowBox[{"\[Mu]", ",", "\[Nu]", ",", "\[Rho]", ",", "\[Sigma]", ",",
        "\[Kappa]", ",", "\[Lambda]"}], ",",
       RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]", ",",
        "\[Delta]"}]}], "}"}]}], "]"}], ";"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
    "Define", " ", "the", " ", "Lorentzian", " ", "metric", " ", "on", " ",
    "M"}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{
   RowBox[{"DefMetric", "[",
    RowBox[{
     RowBox[{"-", "1"}], ",",
     RowBox[{"gMetric", "[",
      RowBox[{"-", "\[Mu]"}], ",",
      RowBox[{"-", "\[Nu]"}], "]"}], ",",
     "CD", ",",
     RowBox[{"{",
      RowBox[{"\"\<g\>\"", ",", "\"\<\[Del]\>\""}], "}"}]}], "]"}], ";"}]}]], \
"Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
    "Define", " ", "the", " ",
    RowBox[{"(", "D-2", ")"},
    "\[Hyphen]dimensional", " ", "sphere", " ", "manifold", " ", "for",
    " ", "the", " ", "angular", " ", "sector"}], " ", "*)"}],
  "\[IndentingNewLine]",
  RowBox[{
   RowBox[{"DefManifold", "[",
    RowBox[{"S", ",",
     RowBox[{"D", "-", "2"}], ",",
     RowBox[{"{",
      RowBox[{"A", ",", "B", ",", "C", ",", "E", ",", "F", ",", "G"}], "}"}]}],
    "]"}], ";"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
    "Round", " ", "metric", " ", "on", " ", "the", " ", "unit", " ",
    RowBox[{"(", "D-2", ")"},
    "\[Hyphen]sphere"}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{
   RowBox[{"DefMetric", "[",
    RowBox[{"1", ",",
     RowBox[{"Omega", "[",
      RowBox[{"-", "A"}], ",",
      RowBox[{"-", "B"}], "]"}], ",",
     "CDS", ",",
     RowBox[{"{",
