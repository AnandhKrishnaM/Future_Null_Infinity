 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{"References"}], " ", "*)"}],
  "\[IndentingNewLine]",
  RowBox[{"(*",
   RowBox[{
    "\[Bullet]", " ",
    RowBox[{
     "Bondi", ",", " ", "van", " ", "der", " ", "Burg", ",", " ",
     "Metzner", " ",
     RowBox[{"(", "1962", ")"}], " ", "Proc.", " ", "R.", " ", "Soc.", " ",
     "London"}]}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{"(*",
   RowBox[{
    "\[Bullet]", " ",
    RowBox[{
     "Sachs", " ",
     RowBox[{"(", "1962", ")"}], " ", "Phys.", " ", "Rev."}]}], " ", "*)"}],
  "\[IndentingNewLine]",
  RowBox[{"(*",
   RowBox[{
    "\[Bullet]", " ",
    RowBox[{
     "Hollands", ",", " ", "Ishibashi", " ",
     RowBox[{"(", "2005", ")"}],
     " ", "Commun.", " ", "Math.", " ", "Phys."}]}], " ", "*)"}],
  "\[IndentingNewLine]",
  RowBox[{"(*",
   RowBox[{
    "\[Bullet]", " ",
    RowBox[{
     "Kapec", ",", " ", "Raclariu", ",", " ", "Strominger", " ",
