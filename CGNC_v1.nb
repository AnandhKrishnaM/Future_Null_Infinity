Cell[TextData[{
 "Metric(s) on the Compact sector  of dimension D-2, the first one is the \
round sphere metric denoted as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["q", "TI"], 
        RowBox[{
          StyleBox["A", "TI"], 
          StyleBox["B", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "q_{AB}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "be1a6826-22cd-c642-bafd-6f057a198960"],
 " and the second one is denoted as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Gamma]", 
        RowBox[{
          StyleBox["A", "TI"], 
          StyleBox["B", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\gamma_{AB}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8b888d8e-2d94-ae4e-98ff-aceffc540c3e"],
 ", the corresponding connections are denoted as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|
     "boxes" -> FormBox["\[Del]", TraditionalForm], "errors" -> {}, "input" -> 
      "\\nabla", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "and", " "}], TraditionalForm]],
  ExpressionUUID->"26cae9e9-9274-b942-b389-3c37ae971fbc"],
 "\[ScriptCapitalD] respectively."
}], "Text",
