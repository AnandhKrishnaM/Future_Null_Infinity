Cell[TextData[{
 "We note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubsuperscriptBox["\[CapitalDelta]\[Gamma]", 
           RowBox[{
             StyleBox["A", "TI"], 
             StyleBox["B", "TI"]}], "1"], "\[LongEqual]", 
          SubscriptBox[
           StyleBox["C", "TI"], 
           RowBox[{
             StyleBox["A", "TI"], 
             StyleBox["B", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\Delta \\gamma_{AB}^{1} = C_{AB}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "e6119d27-9e43-5e44-a7c3-d8c0a2b3a1b5"],
 " (we denote for convenience) is traceless w.r.t to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["q", "TI"], 
        RowBox[{
          StyleBox["A", "TI"], 
          StyleBox["B", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "q^{AB}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bcceb9d8-67ed-8043-b213-d3379239791a"],
 " , and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["q", "TI"], 
        RowBox[{
          StyleBox["A", "TI"], 
          StyleBox["B", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "q^{AB}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "99e097d1-bfc3-a148-9d16-c2c534661247"],
 " is the round metric on the sphere (which is independent of u, r), the \
expression will reduce to just two terms (2 and 3) as below. "
}], "Text",
 CellChangeTimes->{{3.9684288335319805`*^9, 3.968428956569803*^9}, {
  3.96842899547703*^9, 3.9684290067478313`*^9}, {3.968429042592695*^9, 
  3.968429054404604*^9}},ExpressionUUID->"1d28a5e2-ae66-414f-b116-\
ee2e9b8c3e3d"],

