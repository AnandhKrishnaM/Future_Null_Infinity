Cell[BoxData[{
 RowBox[{
  RowBox[{"indiceOf", "[", 
   RowBox[{"a_", ",", "m_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"MatchQ", "[", 
    RowBox[{"a", ",", 
     TagBox[
      StyleBox[
       RowBox[{"PatternTest", "[", 
        RowBox[{
         RowBox[{"Blank", "[", "]"}], ",", 
         RowBox[{"Symbol", "[", 
          RowBox[{"\"\<Tangent\>\"", "<>", 
           RowBox[{"ToString", "[", "m", "]"}], "<>", "\"\<`Q\>\""}], "]"}]}],
         "]"}],
       ShowSpecialCharacters->False,
       ShowStringCharacters->True,
       NumberMarks->True],
      FullForm]}], "]"}], "||", 
   RowBox[{"MatchQ", "[", 
    RowBox[{"a", ",", 
     TagBox[
      StyleBox[
       RowBox[{"PatternTest", "[", 
        RowBox[{
         RowBox[{"Blank", "[", "]"}], ",", 
         RowBox[{"Symbol", "[", 
          RowBox[{
           RowBox[{"ToString", "[", "m", "]"}], "<>", "\"\<`Q\>\""}], "]"}]}],
         "]"}],
       ShowSpecialCharacters->False,
       ShowStringCharacters->True,
       NumberMarks->True],
      FullForm]}], "]"}]}]}], "\n", 
 RowBox[{
  RowBox[{"indicesOf", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a_", ",", "m1_"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"b_", ",", "m2_"}], "}"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"indiceOf", "[", 
    RowBox[{"a", ",", "m1"}], "]"}], "&&", 
   RowBox[{"indiceOf", "[", 
    RowBox[{"b", ",", "m2"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"indices3Of", "[", 
   RowBox[{
    RowBox[{"{", 
